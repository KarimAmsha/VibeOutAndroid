rules_version = '2';

// Firebase Storage rules for profile/place images.
// Anyone signed in can read images; users can only write under their own
// folder. Place images are managed from the console/admin SDK.
service firebase.storage {
  match /b/{bucket}/o {
    match /users/{uid}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }
    match /places/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if false;
    }
  }
}
